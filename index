<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Career Story Lab</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(180deg, #eef6ff, #f8fbff);
      color: #1f2937;
    }

    .container {
      max-width: 1100px;
      margin: 30px auto;
      background: #ffffff;
      border-radius: 18px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.10);
      padding: 28px;
    }

    .logo-wrap {
      text-align: center;
      margin-bottom: 20px;
    }

    .logo {
      max-width: 360px;
      width: 100%;
      height: auto;
      display: inline-block;
    }

    h1, h2, h3 {
      margin-top: 0;
    }

    h1, .center {
      text-align: center;
    }

    .subtitle {
      text-align: center;
      color: #4b5563;
      margin-bottom: 22px;
      line-height: 1.5;
    }

    .hidden {
      display: none;
    }

    .card {
      background: #f9fbff;
      border: 1px solid #dbe7ff;
      border-radius: 14px;
      padding: 20px;
      margin-top: 18px;
    }

    .story-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-top: 18px;
    }

    @media (max-width: 900px) {
      .story-grid {
        grid-template-columns: 1fr;
      }

      .container {
        margin: 15px;
        padding: 20px;
      }

      .logo {
        max-width: 280px;
      }
    }

    .story-card {
      background: #ffffff;
      border: 1px solid #dbe7ff;
      border-radius: 14px;
      padding: 18px;
    }

    .story-card p {
      color: #475569;
      line-height: 1.5;
      min-height: 48px;
    }

    .prompt-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      margin-top: 18px;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-weight: 700;
    }

    input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 10px;
      font-size: 16px;
      border: 1px solid #c9d5ea;
      background: #fff;
    }

    button {
      width: 100%;
      padding: 12px 14px;
      border-radius: 10px;
      font-size: 16px;
      border: none;
      color: #fff;
      font-weight: 700;
      cursor: pointer;
      margin-top: 10px;
    }

    .primary-btn {
      background: #2563eb;
    }

    .primary-btn:hover {
      background: #1d4ed8;
    }

    .secondary-btn {
      background: #64748b;
    }

    .secondary-btn:hover {
      background: #475569;
    }

    .green-btn {
      background: #0f766e;
    }

    .green-btn:hover {
      background: #115e59;
    }

    .button-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 18px;
    }

    .story-output {
      white-space: pre-wrap;
      line-height: 1.85;
      font-size: 18px;
      background: #ffffff;
      border: 1px solid #dbe7ff;
      border-radius: 14px;
      padding: 18px;
      margin-top: 16px;
    }

    .quote-box {
      margin-top: 18px;
      padding: 16px;
      border-radius: 14px;
      background: #ecfdf5;
      border: 1px solid #86efac;
    }

    .quote-text {
      font-size: 18px;
      font-style: italic;
      line-height: 1.6;
      margin-bottom: 8px;
    }

    .quote-author {
      font-weight: 700;
      color: #166534;
    }

    .small {
      color: #64748b;
      font-size: 14px;
      line-height: 1.5;
    }

    .header-pill {
      display: inline-block;
      margin: 0 auto 10px auto;
      padding: 8px 14px;
      background: #eef2ff;
      border: 1px solid #c7d2fe;
      border-radius: 999px;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="logo-wrap">
      <img src="data:image/png;base64," class="logo" alt="Funny Future Plans Logo" />
    </div>

    <div id="homeScreen">
      <h1>Career Story Lab</h1>
      <p class="subtitle">
        Pick a story, fill in the prompts, and generate a ridiculous-but-helpful career story.
        This is basically Mad Libs with better life choices.
      </p>

      <div class="story-grid" id="storyGrid"></div>
    </div>

    <div id="formScreen" class="hidden">
      <div class="center">
        <div class="header-pill">Story Builder</div>
      </div>
      <h2 id="storyTitle"></h2>
      <p class="subtitle" id="storyIntro"></p>

      <div class="card">
        <div class="prompt-list" id="promptContainer"></div>

        <div class="button-row">
          <button class="secondary-btn" onclick="goHome()">Back to Stories</button>
          <button class="green-btn" onclick="generateStory()">Generate Story</button>
        </div>
      </div>
    </div>

    <div id="resultScreen" class="hidden">
      <div class="center">
        <div class="header-pill">Finished Story</div>
      </div>
      <h2 id="resultTitle"></h2>

      <div class="card">
        <div id="storyOutput" class="story-output"></div>

        <div class="quote-box">
          <div class="quote-text" id="quoteText"></div>
          <div class="quote-author" id="quoteAuthor"></div>
        </div>

        <p class="small">
          Reminder: students usually have more in them than they realize. Sometimes they just need a better question,
          a better plan, and slightly fewer bad ideas.
        </p>

        <div class="button-row">
          <button class="secondary-btn" onclick="editCurrentStory()">Edit Answers</button>
          <button class="primary-btn" onclick="goHome()">Choose Another Story</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const quotes = [
      {
        text: "The future belongs to those who believe in the beauty of their dreams.",
        author: "Eleanor Roosevelt"
      },
      {
        text: "You gain strength, courage and confidence by every experience in which you really stop to look fear in the face.",
        author: "Eleanor Roosevelt"
      },
      {
        text: "You must do the thing you think you cannot do.",
        author: "Eleanor Roosevelt"
      },
      {
        text: "Effort and courage are not enough without purpose and direction.",
        author: "John F. Kennedy"
      },
      {
        text: "We must use time as a tool, not as a couch.",
        author: "John F. Kennedy"
      }
    ];

    const stories = [
      {
        id: 1,
        title: "The Extremely Serious Career Conversation",
        intro: "One day, I met with a student who wanted to become a...",
        prompts: [
          "What is your dream job?",
          "What skill or talent do you have?",
          "What is a funny bad habit you or someone has?",
          "Name a random activity someone does",
          "Name a silly job title",
          "What is an important value with working? (good salary, good leadership, helping others, etc.)",
          "Name a shallow quality (slacking at work, being late all the time, stealing, etc.)",
          "What is your future goal with work? (good lifestyle, family, happiness, good bank account, etc.)",
          "Name a large number",
          "Name an interest or hobby you have",
          "Name a ridiculous career you would never do",
          "What big dream do you have?"
        ],
        template:
`One day, I met with a student who wanted to become a "{0}."

They said their biggest strength was "{1},"
but their biggest weakness was "{2}."

When I asked why they chose that career, they said,
"Because I really love {3}
and I don’t want to end up as a {4}."

I nodded seriously and said,
"Have you considered the importance of {5}?"

They blinked at me and said,
"I thought careers were just about {6}."

That’s when I dramatically explained that choosing a career affects your
"{7}"
for approximately "{8}" years.

We then explored careers involving "{9}"
and discovered that with the right plan, certifications, and education,
they could avoid becoming a professional "{10}."

By the end of our conversation, the student realized that career coaching isn’t about telling them what to do —
it’s about helping them turn "{11}"
into a real plan.

And possibly avoiding living in their mom’s basement forever.`
      },
      {
        id: 2,
        title: "When I Grow Up (Middle School Version)",
        intro: "This one is for the future-planning crowd with just enough chaos.",
        prompts: [
          "Name a career",
          "What is something you like doing?",
          "Name a talent you or someone has",
          "What is a silly job?",
          "Name a random food",
          "What is something you wish you had?",
          "Name an important person",
          "Give me a number",
          "List a type of training or type of school",
          "Name a skill that you have",
          "What is something that distracts you?"
        ],
        template:
`When I grow up, I want to be a(n) {0}.

Mainly because I love {1}
and I am amazing at {2}.

I do NOT want to end up as a {3}
living off of {4} forever.

A career coach once told me that my future job should help me:

Earn enough money to buy a {5}

Support my {6}

And feel proud for at least {7} years.

To make that happen, I might need:

{8}

Practice in {9}

And fewer hours spent on {10}.

Turns out "winging it" is not a career plan.`
      },
      {
       let currentStory = null;
    let currentAnswers = [];

    function fillTemplate(template, answers) {
      return template.replace(/\{(\d+)\}/g, (_, index) => {
        return answers[Number(index)] ?? "";
      });
    }

    function randomQuote() {
      return quotes[Math.floor(Math.random() * quotes.length)];
    }

    function showScreen(screenId) {
      document.getElementById("homeScreen").classList.add("hidden");
      document.getElementById("formScreen").classList.add("hidden");
      document.getElementById("resultScreen").classList.add("hidden");
      document.getElementById(screenId).classList.remove("hidden");
    }

    function renderHome() {
      const grid = document.getElementById("storyGrid");
      grid.innerHTML = "";

      stories.forEach(story => {
        const card = document.createElement("div");
        card.className = "story-card";
        card.innerHTML = `
          <h3>${story.id}. ${story.title}</h3>
          <p>${story.intro}</p>
          <div class="small">${story.prompts.length} prompts</div>
          <button class="primary-btn" onclick="openStory(${story.id})">Open Story</button>
        `;
        grid.appendChild(card);
      });
    }

    function openStory(id) {
      currentStory = stories.find(s => s.id === id);
      currentAnswers = new Array(currentStory.prompts.length).fill("");

      document.getElementById("storyTitle").textContent = currentStory.title;
      document.getElementById("storyIntro").textContent = currentStory.intro;

      const container = document.getElementById("promptContainer");
      container.innerHTML = "";

      currentStory.prompts.forEach((prompt, index) => {
        const wrapper = document.createElement("div");
        wrapper.innerHTML = `
          <label for="prompt_${index}">Prompt ${index + 1}: ${prompt}</label>
          <input id="prompt_${index}" type="text" />
        `;
        container.appendChild(wrapper);
      });

      showScreen("formScreen");
    }

    function generateStory() {
      if (!currentStory) return;

      const answers = [];
      for (let i = 0; i < currentStory.prompts.length; i++) {
        const value = document.getElementById(`prompt_${i}`).value.trim();
        if (!value) {
          alert(`Please answer Prompt ${i + 1} before generating the story.`);
          return;
        }
        answers.push(value);
      }

      currentAnswers = answers;

      const finishedStory = fillTemplate(currentStory.template, answers);
      const quote = randomQuote();

      document.getElementById("resultTitle").textContent = currentStory.title;
      document.getElementById("storyOutput").textContent = finishedStory;
      document.getElementById("quoteText").textContent = `"${quote.text}"`;
      document.getElementById("quoteAuthor").textContent = `— ${quote.author}`;

      showScreen("resultScreen");
    }

    function editCurrentStory() {
      if (!currentStory) return;

      showScreen("formScreen");

      currentStory.prompts.forEach((_, index) => {
        const input = document.getElementById(`prompt_${index}`);
        if (input) {
          input.value = currentAnswers[index] || "";
        }
      });
    }

    function goHome() {
      currentStory = null;
      currentAnswers = [];
      showScreen("homeScreen");
    }

    renderHome();
  </script>
</body>
</html>
